# ServerPal unified environment example.
# Copy to .env in the repository root for local runs.

# Production reverse proxy (used by docker-compose.prod.yml)
SERVERPAL_DOMAIN=serverpal.example.com
SERVERPAL_TLS_CERT_PATH=/etc/letsencrypt/live/serverpal.example.com/fullchain.pem
SERVERPAL_TLS_KEY_PATH=/etc/letsencrypt/live/serverpal.example.com/privkey.pem

# Dashboard (9001)
SECRET_KEY=change-me-generate-long-random-string
ENCRYPTION_KEY=change-me-fernet-key
AI_SERVICE_URL=http://127.0.0.1:8001
DIGEST_SERVICE_URL=http://127.0.0.1:8002
ALLOWED_ORIGINS=http://127.0.0.1:9001,http://127.0.0.1:8001,http://127.0.0.1:8002
DASHBOARD_DB_PATH=users.db

# AI Bridge (8001)
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_MODEL=dolphin-2.9.4-llama3.1-8b
SERVICE_API_KEY=change-me
MAX_TOOL_ITERATIONS=5
DATA_DIR=data/connected_bases
LOGS_DIR=logs
KNOWLEDGE_BASE_FILE=knowledge_base.txt
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
REGISTRATION_ENABLED=false
REGISTRATION_TOKEN=
ADMIN_USERNAMES=
ADMIN_PASSWORD=

# Digest API (8002)
DIGEST_OPENAI_API_KEY=
DIGEST_OPENAI_BASE_URL=https://api.hydraai.ru/v1
DIGEST_OPENAI_MODEL=gpt-4o
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=dolphin-2.9.4-llama3.1-8b
DIGEST_REQUEST_TIMEOUT=120
